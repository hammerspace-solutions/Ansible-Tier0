#!/usr/bin/env bash
# Pin NIC IRQs to CPUs on the same NUMA node as the device.
# Generated by perf_tuning role - do not edit by hand.
set -eo pipefail

INTERFACES=( {% for iface in _perf_pin_nics %}"{{ iface }}" {% endfor %})

for iface in "${INTERFACES[@]}"; do
    sys_dev="/sys/class/net/${iface}/device"
    if [[ ! -d "${sys_dev}" ]]; then
        echo "skip ${iface}: not a real device"
        continue
    fi

    numa=$(cat "${sys_dev}/numa_node" 2>/dev/null || echo -1)
    if [[ "${numa}" -lt 0 ]]; then
        echo "skip ${iface}: no NUMA affinity reported"
        continue
    fi

    cpulist=$(cat "/sys/devices/system/node/node${numa}/cpulist" 2>/dev/null || true)
    if [[ -z "${cpulist}" ]]; then
        echo "skip ${iface}: NUMA node ${numa} has no cpulist"
        continue
    fi

    # Convert "0-23,48-71" to a hex affinity mask
    mask=$(python3 -c "
import sys
ranges = '${cpulist}'.split(',')
bits = 0
for r in ranges:
    if '-' in r:
        a, b = r.split('-')
        for c in range(int(a), int(b)+1):
            bits |= (1 << c)
    elif r:
        bits |= (1 << int(r))
print(format(bits, 'x'))
")

    echo "Pinning ${iface} (NUMA ${numa}, cpus ${cpulist})"

    # Find every IRQ associated with this NIC
    for irq in $(grep -E " ${iface}(-|$|\s)" /proc/interrupts | awk -F: '{print $1}' | tr -d ' '); do
        proc_aff="/proc/irq/${irq}/smp_affinity"
        [[ -w "${proc_aff}" ]] || continue
        echo "${mask}" > "${proc_aff}" 2>/dev/null || true
    done
done
