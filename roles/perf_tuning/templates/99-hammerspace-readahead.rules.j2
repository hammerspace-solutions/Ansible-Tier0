# Hammerspace Tier 0 BKM: read-ahead for backing block devices
# Generated by perf_tuning role - do not edit by hand.
#
# read_ahead_kb is set in KB (kernel uses KB for bdi).
# blockdev --setra uses 512-byte sectors (KB * 2).

# NVMe drives
SUBSYSTEM=="block", KERNEL=="nvme[0-9]n[0-9]", ATTR{queue/read_ahead_kb}="{{ perf_readahead_kb }}"

# MD RAID arrays
SUBSYSTEM=="block", KERNEL=="md[0-9]*", ATTR{queue/read_ahead_kb}="{{ perf_readahead_kb }}"

# SCSI/SATA HDDs and SSDs (Hammerspace HDD tier nodes)
SUBSYSTEM=="block", KERNEL=="sd[a-z]", ATTR{queue/read_ahead_kb}="{{ perf_readahead_kb }}"
